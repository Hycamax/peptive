<% const title = t('ok.title') %>
<%- include('partials/header', { title }) %>

<%
const s = settings;
const totalStr = fmt(total);
const waBaseMsg = lang === 'es'
  ? `Hola, soy ${customerName}. Hice el pedido #${orderId} por ${totalStr}. Adjunto comprobante de pago.`
  : `Hi, I'm ${customerName}. I placed order #${orderId} for ${totalStr}. Sending the payment receipt.`;
const waMsg = encodeURIComponent(waBaseMsg);
const waUrl = s.whatsapp ? `https://wa.me/${s.whatsapp}?text=${waMsg}` : null;

const methods = [
  { key: 'mercadopago', label: 'Mercado Pago', tier: 'card', enabled: s.payment_mercadopago_enabled === '1' && s.payment_mercadopago_link, link: s.payment_mercadopago_link, tag: 'Card' },
  { key: 'clip', label: 'Clip', tier: 'card', enabled: s.payment_clip_enabled === '1' && s.payment_clip_link, link: s.payment_clip_link, tag: 'Card' },
  { key: 'nowpayments', label: 'NOWPayments (Card → Crypto)', tier: 'card', enabled: s.payment_nowpayments_enabled === '1' && s.payment_nowpayments_link, link: s.payment_nowpayments_link, tag: 'Private' },
  { key: 'spei', label: 'SPEI', tier: 'manual', enabled: s.payment_spei_enabled === '1' && s.payment_spei_clabe, tag: 'MX' },
  { key: 'oxxo', label: 'OXXO', tier: 'manual', enabled: s.payment_oxxo_enabled === '1' && s.payment_spei_clabe, tag: 'Cash' },
  { key: 'zelle', label: 'Zelle (USD)', tier: 'manual', enabled: s.payment_zelle_enabled === '1' && s.payment_zelle_email, tag: 'US' },
  { key: 'wise', label: 'Wise', tier: 'manual', enabled: s.payment_wise_enabled === '1' && (s.payment_wise_email || s.payment_wise_wisetag), tag: 'Intl' },
  { key: 'eth', label: 'Crypto — ' + (s.payment_eth_network || 'EVM').replace(/\s*\(.*\)/, ''), tier: 'crypto', enabled: s.payment_eth_enabled === '1' && s.payment_eth_address, tag: s.payment_eth_currencies || 'Crypto', address: s.payment_eth_address, network: s.payment_eth_network || 'Ethereum (ERC-20)', qrPrefix: '', currencies: s.payment_eth_currencies || 'USDT, USDC, ETH', warn: true },
  { key: 'btc', label: 'Crypto — Bitcoin', tier: 'crypto', enabled: s.payment_btc_enabled === '1' && s.payment_btc_address, tag: 'BTC', address: s.payment_btc_address, network: 'Bitcoin', qrPrefix: 'bitcoin:', currencies: 'BTC', warn: false }
];
const enabledMethods = methods.filter(m => m.enabled);
const anyEnabled = enabledMethods.length > 0;
%>

<div class="ok-box">
  <h1><%= t('ok.title') %></h1>
  <p><%= t('ok.orderNumber') %> <strong>#<%= orderId %></strong></p>
  <p><%= t('ok.totalToPay') %> <strong style="font-size:1.4rem"><%= totalStr %></strong></p>
  <p class="note"><%= t('ok.holdNote') %></p>
</div>

<% if (!anyEnabled) { %>
  <div class="empty" style="margin: 0 auto; max-width: 720px;">
    <%= t('pm.noneConfigured') %>
    <% if (waUrl) { %><br/><br/><a class="btn btn-primary" href="<%= waUrl %>" target="_blank" rel="noopener"><%= t('pm.coordinateWa') %></a><% } %>
  </div>
<% } else { %>

<section class="payment-section">
  <div class="payment-head">
    <h2><%= t('ok.choose') %></h2>
    <p class="payment-intro"><%- t('ok.intro', { total: totalStr, id: orderId }) %></p>
  </div>

  <div class="payment-grid">
    <% enabledMethods.forEach(m => { %>
      <article class="payment-card payment-card-<%= m.tier %>">
        <header class="payment-card-head">
          <div class="payment-icon" aria-hidden="true">
            <% if (m.tier === 'card') { %>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            <% } else if (m.tier === 'crypto') { %>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            <% } else if (m.key === 'spei' || m.key === 'oxxo') { %>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18M7 15h2M13 15h4"/></svg>
            <% } else { %>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>
            <% } %>
          </div>
          <div class="payment-titles">
            <h3><%= m.label %></h3>
            <% if (m.tag) { %><span class="payment-tag"><%= m.tag %></span><% } %>
          </div>
        </header>

        <% if (m.tier === 'card') { %>
          <a class="btn btn-primary btn-block" href="<%= m.link %>" target="_blank" rel="noopener">
            <%= t('pm.payNow', { amount: totalStr }) %>
          </a>
          <p class="payment-foot"><%= t('pm.foot.portal') %></p>
        <% } else if (m.key === 'spei') { %>
          <ul class="payment-instructions">
            <li><span><%= t('pm.method.spei.bank') %></span><strong><%= s.payment_spei_bank || '—' %></strong></li>
            <li><span><%= t('pm.method.spei.holder') %></span><strong><%= s.payment_spei_holder || '—' %></strong></li>
            <li class="copyable"><span><%= t('pm.method.spei.clabe') %></span><code class="copy-target"><%= s.payment_spei_clabe %></code><button class="btn-copy" data-copy="<%= s.payment_spei_clabe %>" type="button"><%= t('pm.copy') %></button></li>
            <li class="copyable"><span><%= t('pm.method.spei.amount') %></span><code class="copy-target"><%= total %></code><button class="btn-copy" data-copy="<%= total %>" type="button"><%= t('pm.copy') %></button></li>
            <li class="copyable"><span><%= t('pm.method.spei.ref') %></span><code class="copy-target">PED-<%= orderId %></code><button class="btn-copy" data-copy="PED-<%= orderId %>" type="button"><%= t('pm.copy') %></button></li>
          </ul>
        <% } else if (m.key === 'oxxo') { %>
          <ul class="payment-instructions">
            <li><span><%= t('pm.method.spei.bank') %></span><strong><%= s.payment_spei_bank %></strong></li>
            <li class="copyable"><span><%= t('pm.method.spei.clabe') %></span><code class="copy-target"><%= s.payment_spei_clabe %></code><button class="btn-copy" data-copy="<%= s.payment_spei_clabe %>" type="button"><%= t('pm.copy') %></button></li>
            <li><span><%= t('pm.method.spei.ref') %></span><strong>PED-<%= orderId %></strong></li>
          </ul>
          <p class="payment-foot"><%= t('pm.method.oxxo.foot') %></p>
        <% } else if (m.key === 'zelle') { %>
          <ul class="payment-instructions">
            <% if (s.payment_zelle_name) { %><li><span><%= t('pm.method.zelle.beneficiary') %></span><strong><%= s.payment_zelle_name %></strong></li><% } %>
            <li class="copyable"><span><%= t('pm.method.zelle.email') %></span><code class="copy-target"><%= s.payment_zelle_email %></code><button class="btn-copy" data-copy="<%= s.payment_zelle_email %>" type="button"><%= t('pm.copy') %></button></li>
            <li><span><%= t('pm.method.zelle.concept') %></span><strong>PED-<%= orderId %></strong></li>
          </ul>
          <p class="payment-foot"><%= t('pm.method.zelle.foot') %></p>
        <% } else if (m.key === 'wise') { %>
          <ul class="payment-instructions">
            <% if (s.payment_wise_wisetag) { %><li class="copyable"><span><%= t('pm.method.wise.tag') %></span><code class="copy-target"><%= s.payment_wise_wisetag %></code><button class="btn-copy" data-copy="<%= s.payment_wise_wisetag %>" type="button"><%= t('pm.copy') %></button></li><% } %>
            <% if (s.payment_wise_email) { %><li class="copyable"><span><%= t('pm.method.wise.email') %></span><code class="copy-target"><%= s.payment_wise_email %></code><button class="btn-copy" data-copy="<%= s.payment_wise_email %>" type="button"><%= t('pm.copy') %></button></li><% } %>
            <% if (s.payment_wise_note) { %><li><span><%= t('pm.method.wise.details') %></span><strong><%= s.payment_wise_note %></strong></li><% } %>
            <li><span><%= t('pm.method.wise.concept') %></span><strong>PED-<%= orderId %></strong></li>
          </ul>
          <p class="payment-foot"><%= t('pm.method.wise.foot') %></p>
        <% } else if (m.tier === 'crypto') { %>
          <p class="payment-blurb"><%= t('pm.method.crypto.network') %>: <strong><%= m.network %></strong> · <%= t('pm.method.crypto.coins') %>: <strong><%= m.currencies %></strong></p>
          <% if (m.warn) { %>
            <p class="payment-warn"><%- t('pm.method.crypto.warn', { network: m.network }) %></p>
          <% } %>
          <div class="crypto-qr">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&margin=10&data=<%= encodeURIComponent(m.qrPrefix + m.address) %>" alt="QR <%= m.network %>" width="180" height="180" loading="lazy"/>
          </div>
          <div class="copyable wallet-address">
            <code class="copy-target"><%= m.address %></code>
            <button class="btn-copy" data-copy="<%= m.address %>" type="button"><%= t('pm.method.crypto.copyAddr') %></button>
          </div>
          <p class="payment-foot"><%- t('pm.method.crypto.foot', { total: totalStr, coins: m.currencies }) %></p>
        <% } %>
      </article>
    <% }) %>
  </div>

  <% if (waUrl) { %>
    <div class="payment-confirm">
      <p><%= t('pm.confirmPaid') %></p>
      <a class="btn btn-primary btn-lg" href="<%= waUrl %>" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.2-1.7-.8-2-.9-.3-.1-.5-.2-.7.1-.2.3-.8.9-1 1.1-.2.2-.4.2-.7.1-1.7-.9-2.9-1.5-4-3.5-.3-.5.3-.5.8-1.5.1-.2 0-.4 0-.5s-.7-1.7-1-2.3c-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .2.2 2 3.1 4.9 4.3 1.8.8 2.5.9 3.4.7.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.1-1.4-.1-.1-.3-.2-.6-.4M12 2C6.5 2 2 6.5 2 12c0 1.9.5 3.7 1.5 5.3L2 22l4.8-1.5c1.5.8 3.3 1.3 5.2 1.3 5.5 0 10-4.5 10-10S17.5 2 12 2"/></svg>
        <%= t('pm.paidWa') %>
      </a>
    </div>
  <% } %>
</section>

<% } %>

<%- include('partials/footer') %>
