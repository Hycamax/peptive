<%- include('_layout_head') %>

<div class="admin-head">
  <h1><%= p ? 'Editar producto' : 'Nuevo producto' %></h1>
  <a href="/admin/productos" class="btn btn-ghost">← Volver</a>
</div>

<form method="post" action="/admin/productos/guardar" enctype="multipart/form-data" class="admin-form">
  <% if (p) { %><input type="hidden" name="id" value="<%= p.id %>"/><% } %>

  <div class="grid-2">
    <label>Nombre *<input type="text" name="name" value="<%= p ? p.name : '' %>" required /></label>
    <label>Slug (URL)<input type="text" name="slug" value="<%= p ? p.slug : '' %>" placeholder="se genera automáticamente" /></label>
  </div>

  <label>Categoría
    <select name="category_id">
      <option value="">— Sin categoría —</option>
      <% categories.forEach(c => { %>
        <option value="<%= c.id %>" <%= p && p.category_id === c.id ? 'selected' : '' %>><%= c.name %></option>
      <% }) %>
    </select>
  </label>

  <label>Descripción corta
    <input type="text" name="short_description" value="<%= p ? p.short_description : '' %>" />
  </label>

  <label>Descripción completa
    <textarea name="description" rows="6"><%= p ? p.description : '' %></textarea>
  </label>

  <div class="grid-2">
    <label>Presentación<input type="text" name="presentation" value="<%= p ? p.presentation : '' %>" placeholder="Vial 5mg liofilizado" /></label>
    <label>Pureza<input type="text" name="purity" value="<%= p ? p.purity : '' %>" placeholder=">98%" /></label>
  </div>

  <div class="grid-2">
    <label>Precio base (sin descuento) *<input type="number" step="0.01" name="price" value="<%= p ? p.price : '' %>" required /></label>
    <label>Stock<input type="number" name="stock" value="<%= p ? p.stock : 0 %>" /></label>
  </div>

  <label>Imagen del producto
    <input type="file" name="image" accept="image/*" />
    <% if (p && p.image) { %>
      <input type="hidden" name="existing_image" value="<%= p.image %>" />
      <small>Imagen actual: <a href="<%= p.image %>" target="_blank"><%= p.image %></a></small>
    <% } %>
  </label>

  <div class="checkbox-row">
    <label><input type="checkbox" name="active" value="1" <%= !p || p.active ? 'checked' : '' %> /> Activo (visible en tienda)</label>
    <label><input type="checkbox" name="featured" value="1" <%= p && p.featured ? 'checked' : '' %> /> Destacado en home</label>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= p ? 'Guardar cambios' : 'Crear producto' %></button>
    <a href="/admin/productos" class="btn btn-ghost">Cancelar</a>
  </div>
</form>

<%- include('_layout_foot') %>
