<%- include('_layout_head') %>

<div class="admin-head">
  <h1>Productos (<%= products.length %>)</h1>
  <a href="/admin/productos/nuevo" class="btn btn-primary">+ Nuevo producto</a>
</div>

<% if (!products.length) { %>
  <p class="empty">No hay productos. <a href="/admin/productos/nuevo">Crea el primero</a>.</p>
<% } else { %>
  <table class="admin-table">
    <thead><tr><th></th><th>Nombre</th><th>Categoría</th><th>Precio</th><th>Final</th><th>Stock</th><th>Estado</th><th></th></tr></thead>
    <tbody>
      <% products.forEach(p => { %>
        <tr>
          <td>
            <% if (p.image) { %><img src="<%= p.image %>" class="thumb" /><% } else { %><div class="thumb" style="background: var(--bg-elev); display:flex; align-items:center; justify-content:center; color: var(--border)">◇</div><% } %>
          </td>
          <td><strong><%= p.name %></strong><br/><small style="color:var(--text-muted)"><%= p.slug %></small></td>
          <td><%= p.category_name || '—' %></td>
          <td><%= fmt(p.price) %></td>
          <td><strong><%= fmt(applyDiscount(p.price)) %></strong></td>
          <td><%= p.stock %></td>
          <td>
            <% if (p.active) { %><span class="status-pill status-enviado">Activo</span><% } else { %><span class="status-pill status-cancelado">Oculto</span><% } %>
            <% if (p.featured) { %><br/><span class="status-pill status-pagado" style="margin-top:4px">★</span><% } %>
          </td>
          <td class="actions">
            <a href="/admin/productos/<%= p.id %>/editar" class="btn btn-small btn-ghost">Editar</a>
            <form method="post" action="/admin/productos/<%= p.id %>/eliminar" onsubmit="return confirm('¿Eliminar este producto?')" style="display:inline">
              <button type="submit" class="btn btn-small btn-danger">×</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('_layout_foot') %>
