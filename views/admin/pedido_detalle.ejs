<%- include('_layout_head') %>

<div class="admin-head">
  <h1>Pedido #<%= order.id %></h1>
  <a href="/admin/pedidos" class="btn btn-ghost">← Volver</a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:24px; max-width:1100px;">
  <div class="admin-form">
    <h3 style="margin:0">Cliente</h3>
    <p style="margin:0"><strong><%= order.customer_name %></strong></p>
    <p style="margin:0; color:var(--text-muted)">📧 <%= order.customer_email %></p>
    <p style="margin:0; color:var(--text-muted)">📞 <%= order.customer_phone %></p>
    <hr style="border-color:var(--border); margin:8px 0;"/>
    <h3 style="margin:0">Envío</h3>
    <p style="margin:0"><%= order.shipping_address %></p>
    <p style="margin:0"><%= order.city %><% if (order.state) { %>, <%= order.state %><% } %> <%= order.zip %></p>
    <% if (order.notes) { %>
      <hr style="border-color:var(--border); margin:8px 0;"/>
      <h3 style="margin:0">Notas</h3>
      <p style="margin:0"><%= order.notes %></p>
    <% } %>
  </div>

  <div class="admin-form">
    <h3 style="margin:0">Estado</h3>
    <form method="post" action="/admin/pedidos/<%= order.id %>/estado">
      <select name="status" style="background:var(--bg-elev);color:var(--text);border:1px solid var(--border);padding:8px;border-radius:6px;width:100%;">
        <% ['pendiente','pagado','enviado','cancelado'].forEach(s => { %>
          <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-primary" style="margin-top:8px;">Actualizar estado</button>
    </form>
    <hr style="border-color:var(--border); margin:8px 0;"/>
    <h3 style="margin:0">Resumen</h3>
    <div class="summary-row"><span>Subtotal:</span><span><%= fmt(order.subtotal) %></span></div>
    <div class="summary-row"><span>Descuento:</span><span><%= fmt(order.discount) %></span></div>
    <div class="summary-row total"><span>Total:</span><span><%= fmt(order.total) %></span></div>
    <p style="margin:0; color:var(--text-muted); font-size:.85rem">Pedido: <%= new Date(order.created_at).toLocaleString('es-MX') %></p>
  </div>
</div>

<h2 style="margin-top:32px;">Productos</h2>
<table class="admin-table">
  <thead><tr><th>Producto</th><th>P. Unitario</th><th>Cant.</th><th>Subtotal</th></tr></thead>
  <tbody>
    <% items.forEach(i => { %>
      <tr>
        <td><%= i.product_name %></td>
        <td><%= fmt(i.unit_price) %></td>
        <td><%= i.quantity %></td>
        <td><strong><%= fmt(i.line_total) %></strong></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('_layout_foot') %>
