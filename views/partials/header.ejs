<!DOCTYPE html>
<html lang="<%= lang %>" data-theme="<%= settings.theme || 'light' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %><%= settings.store_name %></title>
  <meta name="description" content="<%= settings.store_tagline %>" />
  <link rel="icon" href="/static/img/peptive-seal.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/styles.css" />
  <style>:root { --primary: <%= settings.primary_color || '#B8860B' %>; }</style>
</head>
<body>
  <header class="site-header">
    <div class="header-row">
      <a class="brand" href="/" aria-label="<%= settings.store_name %>">
        <img src="/static/img/peptive-wordmark-approved.png" alt="<%= settings.store_name %>" class="brand-mark" />
      </a>
      <nav class="main-nav">
        <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>"><%= t('nav.home') %></a>
        <a href="/products" class="<%= currentPath.startsWith('/products') || currentPath.startsWith('/product') ? 'active' : '' %>"><%= t('nav.products') %></a>
        <div class="dropdown">
          <button class="dropbtn" type="button"><%= t('nav.categories') %>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="dropdown-content">
            <% categories.forEach(c => { %>
              <a href="/products?category=<%= c.slug %>"><%= c.name %></a>
            <% }) %>
          </div>
        </div>
      </nav>
      <div class="header-actions">
        <form action="/products" method="get" class="search">
          <input type="text" name="q" placeholder="<%= t('nav.searchPlaceholder') %>" aria-label="<%= t('nav.searchPlaceholder') %>" />
        </form>
        <div class="lang-toggle" role="group" aria-label="Language">
          <a href="/lang/en" class="<%= lang === 'en' ? 'active' : '' %>" aria-current="<%= lang === 'en' ? 'true' : 'false' %>">EN</a>
          <a href="/lang/es" class="<%= lang === 'es' ? 'active' : '' %>" aria-current="<%= lang === 'es' ? 'true' : 'false' %>">ES</a>
        </div>
        <button class="theme-toggle" id="themeToggle" title="<%= t('nav.themeToggle') %>" aria-label="<%= t('nav.themeToggle') %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        </button>
        <a class="cart-link" href="/cart" aria-label="<%= t('nav.cart') %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="cart-badge"><%= cartCount %></span>
        </a>
      </div>
    </div>
    <% if (discountPct > 0) { %>
      <div class="promo-bar"><%- t('promo.discount', { pct: discountPct }) %></div>
    <% } %>
  </header>

  <% if (flash) { %>
    <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
  <% } %>

  <main class="container main-content">
