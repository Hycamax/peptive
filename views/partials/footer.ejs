  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="/static/img/peptive-wordmark-approved.png" alt="<%= settings.store_name %>" class="footer-brand-mark" />
        <p><%= settings.store_tagline %></p>
      </div>
      <div>
        <h4><%= t('footer.contact') %></h4>
        <p>📧 <%= settings.contact_email %></p>
        <p>📞 <%= settings.contact_phone %></p>
        <% if (settings.whatsapp) { %>
          <p><a href="https://wa.me/<%= settings.whatsapp %>" target="_blank">WhatsApp</a></p>
        <% } %>
      </div>
      <div>
        <h4><%= t('footer.shipping') %></h4>
        <p><%= settings.shipping_note %></p>
      </div>
      <div>
        <h4><%= t('footer.categories') %></h4>
        <% categories.slice(0, 6).forEach(c => { %>
          <p><a href="/products?category=<%= c.slug %>"><%= c.name %></a></p>
        <% }) %>
      </div>
    </div>
    <div class="container disclaimer">
      <small><%= settings.legal_disclaimer %></small>
      <small><%= t('footer.copyright', { year: new Date().getFullYear(), brand: settings.store_name }) %> · <a href="/admin/login"><%= t('footer.admin') %></a></small>
    </div>
  </footer>

  <script src="/static/js/app.js"></script>
</body>
</html>
