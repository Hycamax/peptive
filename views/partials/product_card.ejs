<%
  const cardSizes = p.sizesArr || null;
  const defSize = cardSizes ? cardSizes[0] : null;
  const cardLabel = defSize ? defSize.label : '';
  const cardPrice = defSize ? defSize.price : p.price;
  const hasMultiple = cardSizes && cardSizes.length > 1;
%>
<article class="product-card">
  <a href="/producto/<%= p.slug %>" class="product-card-link">
    <div class="product-image">
      <% if (p.image) { %>
        <img src="<%= p.image %>" alt="<%= p.name %>" />
      <% } else { %>
        <svg class="vial-icon branded" viewBox="0 0 100 140" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <linearGradient id="liq-<%= p.id %>" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0" stop-color="#B8860B" stop-opacity="0.45"/>
              <stop offset="1" stop-color="#0A0A14" stop-opacity="0.90"/>
            </linearGradient>
            <linearGradient id="cap-<%= p.id %>" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0" stop-color="#D4A017"/>
              <stop offset="1" stop-color="#8B6914"/>
            </linearGradient>
          </defs>
          <rect x="28" y="6" width="44" height="14" rx="2" fill="url(#cap-<%= p.id %>)"/>
          <rect x="28" y="18" width="44" height="3" fill="#B8860B"/>
          <rect x="36" y="21" width="28" height="11" fill="currentColor" fill-opacity=".10" stroke="currentColor" stroke-width=".4" stroke-opacity=".3"/>
          <rect x="22" y="32" width="56" height="100" rx="6" fill="currentColor" fill-opacity=".06" stroke="#B8860B" stroke-width=".6" stroke-opacity=".4"/>
          <path d="M22 88 Q50 84 78 88 L78 126 Q78 132 72 132 L28 132 Q22 132 22 126 Z" fill="url(#liq-<%= p.id %>)"/>
          <rect x="26" y="50" width="48" height="46" fill="#FAF7F2"/>
          <rect x="26" y="50" width="48" height="2" fill="#0A0A14"/>
          <rect x="26" y="94" width="48" height="2" fill="#B8860B"/>
          <text x="50" y="60" text-anchor="middle" font-size="4.5" fill="#0A0A14" font-weight="800" font-family="Inter, sans-serif" letter-spacing="1.4">PEPTIVE</text>
          <line x1="32" y1="63" x2="68" y2="63" stroke="#B8860B" stroke-width=".5"/>
          <text x="50" y="76" text-anchor="middle" font-size="6" fill="#0A0A14" font-weight="700" font-family="Inter, sans-serif"><%= p.name.length > 14 ? p.name.slice(0,13)+'…' : p.name %></text>
          <% if (cardLabel) { %>
            <text x="50" y="89" text-anchor="middle" font-size="7" fill="#B8860B" font-weight="800" font-family="Inter, sans-serif"><%= cardLabel %></text>
          <% } %>
        </svg>
      <% } %>
      <% if (p.featured) { %><span class="badge badge-featured"><%= t('card.featured') %></span><% } %>
      <% if ((p.stock || 0) <= 0) { %><span class="badge badge-out"><%= t('card.soldOut') %></span><% } %>
      <% if (discountPct > 0 && (p.stock || 0) > 0) { %><span class="badge badge-discount">-<%= discountPct %>%</span><% } %>
    </div>
    <div class="product-body">
      <% if (p.category_name) { %><span class="product-cat"><%= p.category_name %></span><% } %>
      <h3 class="product-name"><%= p.name %></h3>
      <p class="product-short"><%= p.short_description %></p>
      <div class="product-prices">
        <% if (hasMultiple) { %><span class="from-label"><%= t('card.from') %></span><% } %>
        <% if (discountPct > 0) { %>
          <span class="price-old"><%= fmt(cardPrice) %></span>
          <span class="price-new"><%= fmt(applyDiscount(cardPrice)) %></span>
        <% } else { %>
          <span class="price-new"><%= fmt(cardPrice) %></span>
        <% } %>
        <% if (hasMultiple) { %><span class="size-count"><%= cardSizes.length %> <%= t('card.sizes') %></span><% } %>
      </div>
      <% if (p.purity) { %><span class="verify-badge">✓ <%= p.purity %></span><% } %>
    </div>
  </a>
</article>
