<% const title = t('nav.cart') %>
<%- include('partials/header', { title }) %>

<h1><%= t('cart.title') %></h1>

<% if (!items.length) { %>
  <p class="empty"><%= t('cart.empty') %></p>
  <a href="/products" class="btn btn-primary"><%= t('cart.viewProducts') %></a>
<% } else { %>
  <form method="post" action="/cart/update">
    <table class="cart-table">
      <thead>
        <tr><th><%= t('cart.col.product') %></th><th><%= t('cart.col.size') %></th><th><%= t('cart.col.price') %></th><th><%= t('cart.col.qty') %></th><th><%= t('cart.col.subtotal') %></th><th></th></tr>
      </thead>
      <tbody>
        <% items.forEach((i, idx) => { %>
          <tr>
            <td><a href="/product/<%= i.slug %>"><%= i.name %></a></td>
            <td><% if (i.size) { %><span class="size-tag"><%= i.size %></span><% } else { %>—<% } %></td>
            <td>
              <% if (discountPct > 0) { %>
                <span class="price-old small"><%= fmt(i.basePrice) %></span>
              <% } %>
              <strong><%= fmt(i.unitPrice) %></strong>
            </td>
            <td>
              <input type="number" name="quantity[<%= idx %>]" value="<%= i.quantity %>" min="0" max="<%= i.stock %>" class="qty-input"/>
            </td>
            <td><strong><%= fmt(i.lineTotal) %></strong></td>
            <td>
              <button type="submit" form="rm-<%= idx %>" class="btn btn-small btn-ghost" aria-label="<%= t('cart.remove') %>">✕</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="cart-actions">
      <button type="submit" class="btn btn-ghost"><%= t('cart.update') %></button>
      <a href="/checkout" class="btn btn-primary"><%= t('cart.checkout') %></a>
    </div>
  </form>

  <% items.forEach((i, idx) => { %>
    <form method="post" action="/cart/remove" id="rm-<%= idx %>" style="display:none">
      <input type="hidden" name="product_id" value="<%= i.id %>" />
      <input type="hidden" name="size" value="<%= i.size || '' %>" />
    </form>
  <% }) %>

  <div class="cart-summary">
    <% if (savings > 0) { %>
      <div class="summary-row"><span><%= t('cart.subtotalRaw') %></span><span class="price-old"><%= fmt(subtotalBase) %></span></div>
      <div class="summary-row"><span><%= t('cart.discount', { pct: discountPct }) %></span><span class="save">- <%= fmt(savings) %></span></div>
    <% } %>
    <div class="summary-row total"><span><%= t('cart.total') %></span><span><%= fmt(total) %></span></div>
  </div>
<% } %>

<%- include('partials/footer') %>
