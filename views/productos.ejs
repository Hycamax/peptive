<% const title = t('catalog.title') %>
<%- include('partials/header', { title }) %>

<div class="catalog-layout">
  <aside class="filters">
    <h3><%= t('nav.categories') %></h3>
    <ul class="filter-list">
      <li><a href="/products" class="<%= !filter.categoria ? 'active' : '' %>"><%= t('catalog.allCategories') %></a></li>
      <% categories.forEach(c => { %>
        <li><a href="/products?category=<%= c.slug %>" class="<%= filter.categoria === c.slug ? 'active' : '' %>"><%= c.name %></a></li>
      <% }) %>
    </ul>
  </aside>

  <div class="catalog-main">
    
    <div class="catalog-head">
      <h1><%= t('catalog.title') %></h1>
      <form method="get" class="sort-form">
        <% if (filter.categoria) { %><input type="hidden" name="categoria" value="<%= filter.categoria %>" /><% } %>
        <% if (filter.q) { %><input type="hidden" name="q" value="<%= filter.q %>" /><% } %>
        <label><%= t('catalog.sortLabel') %>
          <select name="orden" onchange="this.form.submit()">
            <option value="" <%= !filter.orden ? 'selected' : '' %>><%= t('catalog.sort.relevance') %></option>
            <option value="precio_asc" <%= filter.orden === 'precio_asc' ? 'selected' : '' %>><%= t('catalog.sort.priceAsc') %></option>
            <option value="precio_desc" <%= filter.orden === 'precio_desc' ? 'selected' : '' %>><%= t('catalog.sort.priceDesc') %></option>
            <option value="nombre" <%= filter.orden === 'nombre' ? 'selected' : '' %>><%= t('catalog.sort.name') %></option>
          </select>
        </label>
      </form>
    </div>

    <% if (products.length === 0) { %>
      <p class="empty"><%= t('catalog.empty') %></p>
    <% } else { %>
      <div class="product-grid">
        <% products.forEach(p => { %>
          <%- include('partials/product_card', { p }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
