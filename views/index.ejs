<% const title = t('nav.home') %>
<%- include('partials/header', { title }) %>

<section class="hero hero-peptive">
  <div class="hero-molecules" aria-hidden="true"></div>
  <div class="hero-content">
    <span class="hero-eyebrow"><%= t('hero.eyebrow') %></span>
    <h1 class="hero-title">
      <span class="hero-wordmark">PEPTIVE</span>
    </h1>
    <p class="hero-tagline"><%= settings.store_tagline %></p>
    <% if (discountPct > 0) { %>
      <p class="hero-promo"><%= t('hero.promo', { pct: discountPct }) %></p>
    <% } %>
    <div class="hero-actions">
      <a href="/products" class="btn btn-primary btn-lg"><%= t('hero.cta.catalog') %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <% if (settings.whatsapp) { %>
        <a href="https://wa.me/<%= settings.whatsapp %>" target="_blank" rel="noopener" class="btn btn-ghost btn-lg"><%= t('hero.cta.whatsapp') %></a>
      <% } %>
    </div>
    <div class="hero-features">
      <div>✓ <%= t('hero.f1') %></div>
      <div>✓ <%= t('hero.f2') %></div>
      <div>✓ <%= t('hero.f3') %></div>
    </div>
  </div>
</section>

<section class="trust-strip">
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
    </div>
    <div><strong><%= t('trust.purity.title') %></strong><small><%= t('trust.purity.sub') %></small></div>
  </div>
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
    </div>
    <div><strong><%= t('trust.ship.title') %></strong><small><%= t('trust.ship.sub') %></small></div>
  </div>
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    </div>
    <div><strong><%= t('trust.support.title') %></strong><small><%= t('trust.support.sub') %></small></div>
  </div>
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
    </div>
    <div><strong><%= t('trust.stock.title') %></strong><small><%= t('trust.stock.sub') %></small></div>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2><%= t('section.categories') %></h2>
    <a href="/products" class="link"><%= t('section.viewAll') %></a>
  </div>
  <%
    const catIcons = {
      'metabolicos': '<path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m8 6 4-4 4 4"/><path d="M16 18a4 4 0 0 0-8 0"/>',
      'recuperacion': '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>',
      'cognitivos': '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/>',
      'longevidad': '<path d="M12 2v4"/><path d="M12 18v4"/><circle cx="12" cy="12" r="4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/>',
      'inmunidad': '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
      'hormona-de-crecimiento': '<path d="M16 2v2"/><path d="M8 2v2"/><path d="M3 6h18"/><path d="m7 18 5-12 5 12"/><path d="M9 14h6"/>',
      'reproductivos': '<circle cx="12" cy="8" r="5"/><path d="M12 13v8"/><path d="M9 18h6"/>',
      'combos': '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
      'estetica-y-piel': '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/>',
      'accesorios': '<path d="m18 2 4 4"/><path d="m17 7 3-3"/><path d="M19 9 8.7 19.3c-1 1-2.5 1-3.4 0l-.6-.6c-1-1-1-2.5 0-3.4L15 5"/><path d="m9 11 4 4"/><path d="m5 19-3 3"/><path d="m14 4 6 6"/>'
    };
    const fallbackIcon = '<path d="M10 2v7.31"/><path d="M14 9.3V1.99"/><path d="M8.5 2h7"/><path d="M14 9.3a6.5 6.5 0 1 1-4 0"/><path d="M5.52 16h12.96"/>';
  %>
  <div class="category-grid">
    <% categories.forEach(c => { %>
      <a href="/products?category=<%= c.slug %>" class="category-tile" data-letter="<%= c.name.charAt(0) %>">
        <span class="category-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><%- catIcons[c.slug] || fallbackIcon %></svg>
        </span>
        <h3><%= c.name %></h3>
        <p><%= c.description %></p>
      </a>
    <% }) %>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2><%= t('section.featured') %></h2>
    <a href="/products" class="link"><%= t('section.viewAll') %></a>
  </div>
  <% if (featured.length === 0) { %>
    <p class="empty">—</p>
  <% } else { %>
    <div class="product-grid">
      <% featured.forEach(p => { %>
        <%- include('partials/product_card', { p }) %>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
