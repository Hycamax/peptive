<% const title = t('nav.home') %>
<%- include('partials/header', { title }) %>

<section class="hero hero-peptive">
  <div class="hero-molecules" aria-hidden="true"></div>
  <div class="hero-content">
    <span class="hero-eyebrow"><%= t('hero.eyebrow') %></span>
    <h1 class="hero-title">
      <span class="hero-wordmark">PEPTIVE</span>
    </h1>
    <p class="hero-tagline"><%= settings.store_tagline %></p>
    <% if (discountPct > 0) { %>
      <p class="hero-promo"><%= t('hero.promo', { pct: discountPct }) %></p>
    <% } %>
    <div class="hero-actions">
      <a href="/productos" class="btn btn-primary btn-lg"><%= t('hero.cta.catalog') %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <% if (settings.whatsapp) { %>
        <a href="https://wa.me/<%= settings.whatsapp %>" target="_blank" rel="noopener" class="btn btn-ghost btn-lg"><%= t('hero.cta.whatsapp') %></a>
      <% } %>
    </div>
    <div class="hero-features">
      <div>✓ <%= t('hero.f1') %></div>
      <div>✓ <%= t('hero.f2') %></div>
      <div>✓ <%= t('hero.f3') %></div>
    </div>
  </div>
</section>

<section class="trust-strip">
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
    </div>
    <div><strong><%= t('trust.purity.title') %></strong><small><%= t('trust.purity.sub') %></small></div>
  </div>
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
    </div>
    <div><strong><%= t('trust.ship.title') %></strong><small><%= t('trust.ship.sub') %></small></div>
  </div>
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    </div>
    <div><strong><%= t('trust.support.title') %></strong><small><%= t('trust.support.sub') %></small></div>
  </div>
  <div class="trust-item">
    <div class="trust-item-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
    </div>
    <div><strong><%= t('trust.stock.title') %></strong><small><%= t('trust.stock.sub') %></small></div>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2><%= t('section.categories') %></h2>
    <a href="/productos" class="link"><%= t('section.viewAll') %></a>
  </div>
  <div class="category-grid">
    <% categories.forEach(c => { %>
      <a href="/productos?categoria=<%= c.slug %>" class="category-tile" data-letter="<%= c.name.charAt(0) %>">
        <h3><%= c.name %></h3>
        <p><%= c.description %></p>
      </a>
    <% }) %>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2><%= t('section.featured') %></h2>
    <a href="/productos" class="link"><%= t('section.viewAll') %></a>
  </div>
  <% if (featured.length === 0) { %>
    <p class="empty">—</p>
  <% } else { %>
    <div class="product-grid">
      <% featured.forEach(p => { %>
        <%- include('partials/product_card', { p }) %>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
